@model List<taskmvc.Models.TaskItem>

<h2 class="mt-5">Lista de Tarefas - 2026</h2>

<a class="btn btn-primary mt-5" asp-action="Create">Adicionar Tarefa</a>

<table class="table text-center mt-5">

    <thead>
        <tr>
            <th>Id</th>
            <th>Nome</th>
            <th>Finalizada</th>
            <th>Ações</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var task in Model)
        {
            <tr>
                <td>@task.Id</td>
                <td>@task.Name</td>
                <td>@(task.IsDone ? "Sim" : "Não")</td>
                <td>
                    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@task.Id">Editar</a>
                    <form asp-action="Delete"
                          asp-route-id="@task.Id"
                          method="post"
                          style="display:inline;">
                        <button type="submit" class="btn btn-dark">
                            Excluir
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>